# ─────────────────────────────────────────────
#  KhataBill — Environment Configuration
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# ─── PostgreSQL Database ───────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=khatabill
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# ─── JWT Authentication ────────────────────────
# Long random secret — keep this private!
JWT_SECRET=2e9535356979795d02a0311c8a7affedb6d41d0bf42e64e823e6523c14af5a3c719f786ffa539b616621158333139a27174fc2a496241e8bb13ba33c9144d72e
JWT_EXPIRES_IN=7d

# ─── WhatsApp Cloud API (Meta) ─────────────────
# 1. Go to https://developers.facebook.com → My Apps → Create App → Business
# 2. Add "WhatsApp" product to the app
# 3. Get these values from WhatsApp > API Setup

# A random string YOU choose — used to verify webhook registration
WHATSAPP_VERIFY_TOKEN=e8500db8ef5a8657a62ec286fd669c2d6d0c36c5e1d25c8e5a036d9c86ffc0dd

# Permanent token from Meta Business Suite (or System User token)
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here

# Phone Number ID shown in WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# WhatsApp Business Account ID
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id_here
