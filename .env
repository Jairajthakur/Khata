# ─────────────────────────────────────────────
#  KhataBill — Environment Configuration
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# ─── PostgreSQL Database ───────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=khatabill
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# ─── JWT Authentication ────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ─── WhatsApp Cloud API (Meta) ─────────────────
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id_here

# ─── WhiteBooks GSP API — Static IP Egress Proxy ──
#
# If you see "Cannot reach WhiteBooks API: fetch failed" on Railway,
# WhiteBooks is blocking your server's dynamic IP.
#
# OPTION A — Fixie proxy (free tier: 500 req/month)
#   Sign up at https://usefixie.com, paste URL below, whitelist their IPs with WhiteBooks
#
# OPTION B — Self-hosted Nginx proxy on a VPS with fixed IP
#   e.g. http://user:pass@1.2.3.4:3128
#
# OPTION C — Railway Pro static IP add-on, then ask WhiteBooks to whitelist it
#
# Leave blank if running locally or already on a static IP.
WHITEBOOKS_PROXY_URL=
