# ─── WhiteBooks GSP API — PROXY REQUIRED ON RAILWAY ──────────────────────────
#
# Railway uses dynamic IPs. WhiteBooks GSP blocks connections from unknown IPs.
# You MUST route WhiteBooks traffic through a static-IP egress proxy.
#
# SETUP STEPS:
#   1. In Railway Dashboard → your project → + New → search "Fixie" → Add
#      Fixie auto-sets the FIXIE_URL env var on your service.
#   2. Copy the FIXIE_URL value and paste it below as WHITEBOOKS_PROXY_URL.
#   3. Log in to developer.whitebooks.in → your GSTIN → IP Whitelist
#      Add the static IP that Fixie gave you.
#   4. Redeploy. Test via: GET https://your-app.railway.app/api/wb-ping
#
# Example (replace with your actual Fixie URL):
#   WHITEBOOKS_PROXY_URL=http://fixie:YOURKEY@criterium.usefixie.com:80
#
WHITEBOOKS_PROXY_URL=

# If you added Fixie as a Railway addon, it sets FIXIE_URL automatically.
# The app will use FIXIE_URL as a fallback if WHITEBOOKS_PROXY_URL is empty.
# FIXIE_URL=http://fixie:YOURKEY@criterium.usefixie.com:80


# ─── WhiteBooks Environment ────────────────────────────────────────────────────
# Set to "production" ONLY when you have a paid WhiteBooks plan and want to use
# production keys (gsp.whitebooks.in). Leave blank or "sandbox" for testing
# (uses apisandbox.whitebooks.in — no proxy needed for sandbox!).
WHITEBOOKS_ENV=sandbox
