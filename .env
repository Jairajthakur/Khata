PORT=5000
NODE_ENV=production

# ─── PostgreSQL ────────────────────────────────
# OPTION A (preferred on Railway): single connection string.
# Copy the "Postgres Connection URL" from Railway → your Postgres service → Connect tab.
# It looks like: postgresql://postgres:PASSWORD@postgres.railway.internal:5432/railway
DATABASE_URL=postgresql://postgres:AsbrEALJaqMzGEgnsPxnbniLZFHcGGDC@postgres.railway.internal:5432/railway

# OPTION B: individual vars (used only when DATABASE_URL is not set)
DB_HOST=postgres.railway.internal
DB_PORT=5432
DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=AsbrEALJaqMzGEgnsPxnbniLZFHcGGDC

# Set to "false" only if your Postgres host does not use SSL (e.g. local dev)
DB_SSL=false

# ─── JWT Authentication ────────────────────────
JWT_SECRET=2e9535356979795d02a0311c8a7affedb6d41d0bf42e64e823e6523c14af5a3c719f786ffa539b616621158333139a27174fc2a496241e8bb13ba33c9144d72e
JWT_EXPIRES_IN=7d

# ─── WhatsApp Cloud API (Meta) ─────────────────
WHATSAPP_VERIFY_TOKEN=e8500db8ef5a8657a62ec286fd669c2d6d0c36c5e1d25c8e5a036d9c86ffc0dd
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id_here

# ─── WhiteBooks GSP API ────────────────────────
